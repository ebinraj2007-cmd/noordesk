# Everything here would otherwise be copied into the image.
#
# This file is not housekeeping. `.env` and `.venv` are the two that matter:
# one can carry live credentials into a layer that persists even if a later
# instruction deletes the file, and the other carries a host-specific Python
# install that would shadow the one we built.

# secrets — never in an image
.env
.env.*
*.pem
*.key
credentials.json
auth_info*/

# host-specific Python
.venv/
venv/
__pycache__/
*.py[cod]
.pytest_cache/
*.egg-info/

# local data — the image ships empty, the volume provides state
*.db
*.db-wal
*.db-shm
data/
profile.json

# git and CI
.git/
.github/
.gitignore

# dev-only
tests/
node_modules/
*.command
docs/
*.md
!README.md

# editor / OS noise
.DS_Store
.vscode/
.idea/

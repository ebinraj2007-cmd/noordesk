# Copy to .env and fill in before exposing NoorDesk beyond localhost.
NOORDESK_TOKEN=            # operator bearer token (openssl rand -hex 32)
NOORDESK_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
NOORDESK_DB=               # path to the SQLite db (defaults to ~/.noordesk/noordesk.db)
NOORDESK_DATA_ROOT=        # allowlisted root for inbox folders
NOORDESK_RATE=120          # default per-IP requests/min
NOORDESK_RATE_STRICT=12    # per-IP requests/min on run/ingest/clear
NOORDESK_LOG_LEVEL=INFO
